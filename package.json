    "jsdom": "^29.0.1",
    "sharp": "^0.34.5",
    "svelte": "^5.53.12",
    "svelte-check": "^4.4.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
